{
  "name": "s3-upload-container",
  "version": "1.0.0",
  "description": "Dockerized AWS S3 uploader using AWS CDK",
  "main": "cdk/index.js",
  "scripts": {
    "cdk:deploy": "cdk deploy --app 'node cdk/index.js'",
    "cdk:destroy": "cdk destroy --app 'node cdk/index.js'",
    "cdk:diff": "cdk diff --app 'node cdk/index.js'",
    "cdk:synth": "cdk synth --app 'node cdk/index.js'",
    "test": "jest --runInBand --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.0.0",
    "constructs": "^10.0.0"
  },
  "devDependencies": {
    "aws-cdk": "^2.0.0",
    "jest": "^29.0.0",
    "aws-sdk-mock": "^5.8.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "dotenv": "^16.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["cdk/**/*.js"]
  }
}
